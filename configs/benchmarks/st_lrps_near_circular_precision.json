{
  "schema_version": 1,
  "name": "st_lrps_near_circular_precision",
  "description": "1-day near-circular precision benchmark for low lunar mapping orbits",
  "scenario": {
    "seed": 42,
    "count": 100,
    "type": "near_circular_altitude",
    "altitude_min_km": 200.0,
    "altitude_max_km": 400.0,
    "eccentricity_mode": "near_circular",
    "inclination_mode": "full_range"
  },
  "propagation": {
    "duration_days": 1.0,
    "output_dt_s": 60.0,
    "integrator": "RK4",
    "dt_s": 10.0,
    "dtype": "float64"
  },
  "truth": {
    "model": "spherical_harmonics",
    "degree": 200,
    "integrator": "DOP853",
    "rtol": 1.0e-10,
    "atol": 1.0e-12,
    "gravity_file": null
  },
  "baselines": [
    {"name": "SH20", "model": "spherical_harmonics", "degree": 20},
    {"name": "SH100", "model": "spherical_harmonics", "degree": 100}
  ],
  "surrogate": {
    "enabled": true,
    "name": "ST-LRPS",
    "model_dir": null,
    "baseline_degree": 20,
    "runtime_model_kind": "potential_autograd"
  },
  "outputs": {
    "out_dir": null,
    "write_figures": true,
    "write_csv": true,
    "write_json": true
  }
}
